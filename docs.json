{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Garth",
  "description": "Garth is an AI-powered code review agent that helps developers write better code by providing intelligent, context-aware feedback on pull requests.",
  "colors": {
    "primary": "#7C3AED",
    "light": "#1da6c8",
    "dark": "#7C3AED"
  },
  "background":{
    "decoration": "grid"
  },
  "favicon": "/logo/garth.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview"
            ]
          },
          {
            "group": "Setup your repository",
            "pages": [
              "setup/github",
              "setup/bitbucket",
              "setup/gitlab",
              "setup/azure-devops"
            ]
          },
          {
            "group": "Pull request review",
            "pages": [
              "pull-request-review/features",
              "pull-request-review/repository-configuration",
              "pull-request-review/customize-review"
            ]
          },
          {
            "group": "Code scan",
            "pages": [
              "code-scan/features",
              "code-scan/code-security",
              "code-scan/code-quality",
              "code-scan/repository-configuration"
            ]
          }
        ]
      },
      {
        "tab": "Pull Request Review",
        "groups": [
          {
            "group": "Pull request review",
            "pages": [
              "pull-request-review/features",
              "pull-request-review/repository-configuration",
              "pull-request-review/customize-review"
            ]
          }
        ]
      },
      {
        "tab": "Code Scan",
        "groups": [
          {
            "group": "Code scan",
            "pages": [
              "code-scan/features",
              "code-scan/code-security",
              "code-scan/code-quality",
              "code-scan/repository-configuration"
            ]
          }
        ]
      }
    ]
  },
  "icons": {
    "library": "fontawesome"
  },
  "logo": {
    "light": "/logo/garth_light.png",
    "dark": "/logo/garth_dark.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Support",
      "href": "mailto:supports@darner.ai"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude"
   ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/darnerai"
    },
    "links": [
      {
        "header": "Company",
        "items": [
          {
            "label": "Darner",
            "href": "https://darner.ai/"
          }
        ]
      },
      {
        "header": "Products",
        "items": [
          {
            "label": "PR Review Agent",
            "href": "https://heygarth.ai/products/pr-review-agent/"
          },
          {
            "label": "Code Scan Agent",
            "href": "https://heygarth.ai/products/pr-code-agent/"
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/overview"
    }
  ]
}
